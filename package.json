{
  "name": "NexCode-ide",
  "productName": "NexCode IDE",
  "version": "3.5.7-Insider.6",
  "description": "NexCode IDE — desktop code editor",
  "main": "dist/main/main.js",
  "author": {
    "name": "Hyggshi OS major project center",
    "email": "hyggshidev@gmail.com"
  },
  "homepage": "https://github.com/Hyggshi-OS-project-center/NexCode",
  "license": "MIT",
  "scripts": {
    "buildfast:Nocompile": "cross-env VITE_NO_SOURCEMAP=1 vite build",
    "buildfast": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" VITE_NO_SOURCEMAP=1 vite build && npm run build:main",
    "debug": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "Devtools": "concurrently \"npm run dev:renderer\" \"npm run dev:electron-devtools\"",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:vite": "cross-env NODE_ENV=development vite --config vite.config.ts",
    "dev:electron": "wait-on -t 60000 http://localhost:5173 && npm run build:main && cross-env VITE_DEV_SERVER=1 electron .",
    "dev:renderer": "cross-env NODE_ENV=development vite --config vite.config.ts",
    "icons": "node scripts/generate-icons.mjs && node scripts/ensure-default-win32-icon.mjs && node scripts/normalize-win32-icons.mjs && node scripts/copy-win32-icons.mjs",
    "build": "npm run icons && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build && npm run build:agent-renderer",
    "build:agent-renderer": "node scripts/copy-agent-renderer.mjs",
    "build:themes-hsixet": "node scripts/build-theme-hsixet.cjs",
    "build:renderer-web": "npm run build:renderer && npx vite --config vite.config.ts",
    "renderer:web": "npx vite --config vite.config.ts",
    "prepack:clean": "node scripts/prepack-clean.mjs",
    "pack": "npm run build && node scripts/pack-installer.mjs",
    "pack:portable": "npm run build && node scripts/pack-portable.mjs",
    "packfast:portable": "npm run buildfast && node scripts/pack-portable.mjs",
    "pack:linux": "npm run build && node scripts/pack-linux.mjs",
    "pack:portable:linux": "npm run build && node scripts/pack-portable.mjs --linux",
    "start": "electron .",
    "check": "npm run typecheck && npm run build:main && npm run build:renderer",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "decode-ico": "^0.4.1",
    "electron": "37.2.1",
    "electron-builder": "^25.1.8",
    "fflate": "^0.8.3",
    "monaco-editor": "^0.55.1",
    "pdfjs-dist": "^4.0.269",
    "rcedit": "^5.0.2",
    "sharp": "^0.33.5",
    "to-ico": "^1.1.5",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "extends": "./electron-builder.config.cjs",
    "appId": "com.nexcode.ide",
    "productName": "NexCode IDE",
    "icon": "build/icon.ico",
    "afterPack": "./scripts/after-pack.cjs",
    "directories": {
      "output": "dist/pack-out",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "src/renderer/public/insider-icon.ico",
        "to": "insider-icon.ico"
      }
    ],
    "files": [
      "dist/main/**/*",
      "dist/agents/**/*",
      "dist/renderer/**/*",
      "dist/shared/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "icon.ico",
      "executableName": "NexCode IDE",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64",
            "ia32"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64",
            "ia32"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-setup.${ext}",
      "shortcutName": "NexCode IDE",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "license": "LICENSE",
      "include": "scripts/installer.nsh"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "executableName": "nexcode-ide",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "maintainer": "Hyggshi OS major project center <hyggshidev@gmail.com>",
      "desktop": {
        "Name": "NexCode IDE",
        "StartupWMClass": "nexcode-ide"
      },
      "executableArgs": [
        "--no-sandbox"
      ],
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "deb": {
      "packageCategory": "devel",
      "artifactName": "nexcode-ide-${version}-${arch}.${ext}",
      "fpm": [
        "--name",
        "nexcode-ide",
        "--deb-priority",
        "optional"
      ],
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "libasound2"
      ]
    }
  }
}